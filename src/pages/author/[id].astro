---
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { calculateReadingTime } from '../../utils/reading-time';
import { generateJsonLd } from '../../utils/seo';

export async function getStaticPaths() {
  const authors = await getCollection('authors');
  return authors.map((author: CollectionEntry<'authors'>) => ({
    params: { id: author.id },
    props: { author },
  }));
}

interface Props {
  author: CollectionEntry<'authors'>;
}

const { author } = Astro.props;

const allPosts = await getCollection('posts', ({ data }: { data: { draft?: boolean } }) => !data.draft);
const authorPosts = allPosts
  .filter((post: CollectionEntry<'posts'>) => post.data.author === author.id || (!post.data.author && author.id === 'ken'))
  .sort((a: CollectionEntry<'posts'>, b: CollectionEntry<'posts'>) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const jsonLd = generateJsonLd({
  type: 'Person',
  title: author.data.name,
  description: author.data.bio,
  canonicalPath: `/author/${author.id}`,
});
---

<BaseLayout
  title={`${author.data.name} | Ken's Blog`}
  description={author.data.bio}
  canonicalUrl={`/author/${author.id}`}
  ogType="profile"
  jsonLd={jsonLd}
>
  <main class="max-w-3xl mx-auto px-6 py-24">
    <div class="animate-fade-in">
      <div class="flex flex-col items-center mb-12">
        <img
          src={author.data.avatar}
          alt={`Portrait of ${author.data.name}`}
          class="w-40 h-40 rounded-full object-cover mb-8"
          width="160"
          height="160"
        />
        <h1 class="font-display text-display-sm md:text-display-md text-foreground">
          {author.data.name}
        </h1>
        <p class="text-foreground-secondary text-lg leading-relaxed font-sans max-w-2xl mx-auto mt-6 text-center">
          {author.data.bio}
        </p>
      </div>

      <div class="mt-16">
        <h2 class="text-foreground-muted text-sm uppercase tracking-[0.3em] mb-8 font-sans font-medium">
          Posts by {author.data.name}
        </h2>
        <div class="space-y-12">
          {authorPosts.map((post: CollectionEntry<'posts'>, index: number) => (
            <article class="group animate-fade-in" style={`animation-delay: ${index * 100}ms`}>
              <div class="flex items-baseline justify-between mb-2">
                <div class="flex items-center gap-2">
                  <time class="text-foreground-muted text-sm font-sans uppercase tracking-wider">
                    {post.data.pubDate.toLocaleDateString('en-US', {
                      year: 'numeric',
                      month: 'short',
                      day: 'numeric',
                    })}
                  </time>
                  <span class="text-foreground-muted text-sm font-sans uppercase tracking-wider">·</span>
                  <span class="text-foreground-muted text-sm font-sans uppercase tracking-wider">{calculateReadingTime(post.body)} min read</span>
                </div>
                {post.data.tags && post.data.tags.length > 0 && (
                  <a
                    href={`/tags/${post.data.tags[0]}`}
                    class="text-foreground-muted text-xs uppercase tracking-wider font-sans hover:text-foreground transition-colors duration-200"
                    aria-label={`Posts tagged ${post.data.tags[0]}`}
                  >
                    {post.data.tags[0]}
                  </a>
                )}
              </div>
              <a href={`/blog/${post.id}`} class="block">
                <h3 class="font-display text-2xl md:text-3xl text-foreground group-hover:text-foreground-secondary transition-colors duration-200 leading-tight">
                  {post.data.title}
                </h3>
                {post.data.description && (
                  <p class="text-foreground-secondary mt-2 text-base leading-relaxed font-sans">
                    {post.data.description}
                  </p>
                )}
              </a>
            </article>
          ))}
        </div>
      </div>

      <footer class="mt-16 pt-8 border-t border-background-elevated">
        <a
          href="/blog"
          class="text-foreground-muted hover:text-foreground text-sm uppercase tracking-wider font-sans transition-colors duration-200"
        >
          ← Back to all posts
        </a>
      </footer>
    </div>
  </main>
</BaseLayout>
