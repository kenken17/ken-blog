---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import SortOrderToggle from '../../components/SortOrderToggle.astro';
import { getAllTags, getPostsByTag } from '../../utils/tags';
import { generateJsonLd } from '../../utils/seo';
import type { CollectionEntry } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('posts', ({ data }: { data: { draft?: boolean } }) => !data.draft);
  const tags = getAllTags(posts);

  return tags.map((tag: string) => ({
    params: { tag },
    props: { tag },
  }));
}

interface Props {
  tag: string;
}

const { tag } = Astro.props;
const allPosts = (await getCollection('posts', ({ data }: { data: { draft?: boolean } }) => !data.draft))
  .sort((a: CollectionEntry<'posts'>, b: CollectionEntry<'posts'>) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const posts = getPostsByTag(allPosts, tag);

const jsonLd = [
  generateJsonLd({
    type: 'CollectionPage',
    title: `Tag: ${tag}`,
    description: `All posts tagged "${tag}" on Ken's blog.`,
    canonicalPath: `/tags/${tag}`,
  }),
  generateJsonLd({
    type: 'BreadcrumbList',
    title: `Tag: ${tag}`,
    breadcrumbs: [
      { name: 'Home', url: '/' },
      { name: 'Tags', url: '/tags' },
      { name: tag, url: `/tags/${tag}` },
    ],
  }),
];
---

<BaseLayout
  title={`Tag: ${tag} | Ken's Blog`}
  description={`All posts tagged "${tag}" on Ken's blog.`}
  canonicalUrl={`/tags/${tag}`}
  ogType="website"
  jsonLd={jsonLd}
>
  <main class="max-w-3xl mx-auto px-6 py-24">
    <div class="mb-16 animate-fade-in">
      <p class="text-foreground-muted text-sm uppercase tracking-[0.3em] mb-4 font-sans font-medium">
        Tag
      </p>
      <h1 class="font-display text-display-sm md:text-display-md text-foreground uppercase">
        {tag}
      </h1>
      <div class="flex items-center justify-between mt-4">
        <p class="text-foreground-secondary text-lg">
          {posts.length} post{posts.length !== 1 ? 's' : ''}
        </p>
        <SortOrderToggle />
      </div>
    </div>

    {posts.length === 0 ? (
      <p class="text-foreground-secondary text-lg animate-fade-in">
        No posts found for this tag.
      </p>
    ) : (
      <div class="space-y-12" data-posts-container>
        {posts.map((post: CollectionEntry<'posts'>, index: number) => (
          <article class="group animate-fade-in" data-pub-date={post.data.pubDate.toISOString()} style={`animation-delay: ${index * 100}ms`}>
            <a href={`/blog/${post.id}`} class="block">
              <div class="flex items-baseline justify-between mb-2">
                <time class="text-foreground-muted text-sm font-sans uppercase tracking-wider">
                  {post.data.pubDate.toLocaleDateString('en-US', {
                    year: 'numeric',
                    month: 'short',
                    day: 'numeric',
                  })}
                </time>
              </div>
              <h2 class="font-display text-2xl md:text-3xl text-foreground group-hover:text-foreground-secondary transition-colors duration-200 leading-tight">
                {post.data.title}
              </h2>
              {post.data.description && (
                <p class="text-foreground-secondary mt-2 text-base leading-relaxed font-sans">
                  {post.data.description}
                </p>
              )}
            </a>
          </article>
        ))}
      </div>
    )}

    <div class="mt-16 pt-8 border-t border-background-elevated animate-fade-in">
      <a
        href="/tags"
        class="text-foreground-muted hover:text-foreground text-sm uppercase tracking-wider font-sans transition-colors duration-200"
      >
        ← All tags
      </a>
    </div>
  </main>

  <script>
    import { getEffectiveSortOrder, type SortOrder } from '../../utils/sort-order.ts';

    function reorderPosts(order: SortOrder) {
      const container = document.querySelector<HTMLDivElement>('[data-posts-container]');
      if (!container) return;

      const articles = Array.from(container.querySelectorAll<HTMLElement>('[data-pub-date]'));
      if (articles.length === 0) return;

      const sorted = articles.sort((a, b) => {
        const aDate = a.getAttribute('data-pub-date') ?? '';
        const bDate = b.getAttribute('data-pub-date') ?? '';
        if (order === 'chronological') {
          return aDate.localeCompare(bDate);
        }
        return bDate.localeCompare(aDate);
      });

      sorted.forEach((article, index) => {
        article.style.animationDelay = `${index * 100}ms`;
        container.appendChild(article);
      });
    }

    // Apply stored preference on initial load
    const initialOrder = getEffectiveSortOrder();
    reorderPosts(initialOrder);

    // Listen for toggle changes
    window.addEventListener('sort-order:change', (event: Event) => {
      const customEvent = event as CustomEvent<{ order: SortOrder }>;
      reorderPosts(customEvent.detail.order);
    });
  </script>
</BaseLayout>
