---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import OrderToggle from '../../components/OrderToggle.astro';
import { getAllTags, getPostsByTag } from '../../utils/tags';
import { generateJsonLd } from '../../utils/seo';
import type { CollectionEntry } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('posts', ({ data }: { data: { draft?: boolean } }) => !data.draft);
  const tags = getAllTags(posts);

  return tags.map((tag: string) => ({
    params: { tag },
    props: { tag },
  }));
}

interface Props {
  tag: string;
}

const { tag } = Astro.props;
const allPosts = await getCollection('posts', ({ data }: { data: { draft?: boolean } }) => !data.draft);
const posts = getPostsByTag(allPosts, tag, 'desc');

const jsonLd = [
  generateJsonLd({
    type: 'CollectionPage',
    title: `Tag: ${tag}`,
    description: `All posts tagged "${tag}" on Ken's blog.`,
    canonicalPath: `/tags/${tag}`,
  }),
  generateJsonLd({
    type: 'BreadcrumbList',
    title: `Tag: ${tag}`,
    breadcrumbs: [
      { name: 'Home', url: '/' },
      { name: 'Tags', url: '/tags' },
      { name: tag, url: `/tags/${tag}` },
    ],
  }),
];
---

<BaseLayout
  title={`Tag: ${tag} | Ken's Blog`}
  description={`All posts tagged "${tag}" on Ken's blog.`}
  canonicalUrl={`/tags/${tag}`}
  ogType="website"
  jsonLd={jsonLd}
>
  <main class="max-w-3xl mx-auto px-6 py-24">
    <div class="mb-16 animate-fade-in">
      <p class="text-foreground-muted text-sm uppercase tracking-[0.3em] mb-4 font-sans font-medium">
        Tag
      </p>
      <h1 class="font-display text-display-sm md:text-display-md text-foreground uppercase">
        {tag}
      </h1>
      <div class="mt-4 flex items-center gap-4">
        <p class="text-foreground-secondary text-lg">
          {posts.length} post{posts.length !== 1 ? 's' : ''}
        </p>
        <OrderToggle currentOrder="desc" controls="tag-post-list" />
      </div>
    </div>

    {posts.length === 0 ? (
      <p class="text-foreground-secondary text-lg animate-fade-in">
        No posts found for this tag.
      </p>
    ) : (
      <div id="tag-post-list" data-sort-list="tag-posts" class="space-y-12">
        {posts.map((post: CollectionEntry<'posts'>, index: number) => (
          <article
            data-sort-item
            data-pub-date={String(post.data.pubDate.valueOf())}
            class="group animate-fade-in"
            style={`animation-delay: ${index * 100}ms`}
          >
            <a href={`/blog/${post.id}`} class="block">
              <div class="flex items-baseline justify-between mb-2">
                <time class="text-foreground-muted text-sm font-sans uppercase tracking-wider">
                  {post.data.pubDate.toLocaleDateString('en-US', {
                    year: 'numeric',
                    month: 'short',
                    day: 'numeric',
                  })}
                </time>
              </div>
              <h2 class="font-display text-2xl md:text-3xl text-foreground group-hover:text-foreground-secondary transition-colors duration-200 leading-tight">
                {post.data.title}
              </h2>
              {post.data.description && (
                <p class="text-foreground-secondary mt-2 text-base leading-relaxed font-sans">
                  {post.data.description}
                </p>
              )}
            </a>
          </article>
        ))}
      </div>
    )}

    <div class="mt-16 pt-8 border-t border-background-elevated animate-fade-in">
      <a
        href="/tags"
        class="text-foreground-muted hover:text-foreground text-sm uppercase tracking-wider font-sans transition-colors duration-200"
      >
        ← All tags
      </a>
    </div>
  </main>

  <script>
    import { getSortPreference, setSortPreference } from '../../utils/sortPreference.ts';
    import type { SortOrder } from '../../utils/sortPreference.ts';

    function getTimestamp(element: HTMLElement): number {
      const rawValue = element.dataset.pubDate;
      const timestamp = Number(rawValue);
      return Number.isFinite(timestamp) ? timestamp : 0;
    }

    function sortList(listElement: HTMLElement, order: SortOrder): void {
      const items = Array.from(listElement.querySelectorAll<HTMLElement>('[data-sort-item]'));

      items.sort((a, b) => {
        const diff = getTimestamp(a) - getTimestamp(b);
        return order === 'asc' ? diff : -diff;
      });

      for (const item of items) {
        listElement.appendChild(item);
      }
    }

    const listElement = document.querySelector<HTMLElement>('[data-sort-list="tag-posts"]');

    if (listElement) {
      const initialOrder = getSortPreference();
      sortList(listElement, initialOrder);

      window.dispatchEvent(new CustomEvent('blog:sort-order-set', {
        detail: { order: initialOrder },
      }));

      window.addEventListener('blog:sort-order-changed', (event: Event) => {
        const customEvent = event as CustomEvent<{ order?: SortOrder }>;
        const order = customEvent.detail?.order === 'asc' ? 'asc' : 'desc';

        sortList(listElement, order);
        setSortPreference(order);
      });
    }
  </script>
</BaseLayout>
