---
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import { generateMetaTags, generateJsonLd } from '../utils/seo';

const PAGE_TITLE = "404 - Page Not Found | Ken's Blog";
const PAGE_DESCRIPTION = "The page you are looking for could not be found. Try searching for a post or head back to the homepage.";
const PAGE_CANONICAL = '/404';

const metaTags = generateMetaTags({
  title: PAGE_TITLE,
  description: PAGE_DESCRIPTION,
  canonicalPath: PAGE_CANONICAL,
  ogType: 'website',
});

const description = metaTags.find((tag) => tag.name === 'description')?.content ?? PAGE_DESCRIPTION;

const recentPosts = (await getCollection('posts', ({ data }: { data: { draft?: boolean } }) => !data.draft))
  .sort((a: CollectionEntry<'posts'>, b: CollectionEntry<'posts'>) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

const jsonLd = generateJsonLd({
  type: 'CollectionPage',
  title: PAGE_TITLE,
  description,
  canonicalPath: PAGE_CANONICAL,
});
---

<BaseLayout
  title={PAGE_TITLE}
  description={description}
  canonicalUrl={PAGE_CANONICAL}
  ogType="website"
  jsonLd={jsonLd}
>
  <main class="max-w-3xl mx-auto px-6 py-16 md:py-24" aria-labelledby="error-title">
    <section class="text-center space-y-4 animate-fade-in" aria-describedby="error-message">
      <p class="text-foreground-muted text-sm uppercase tracking-[0.3em] font-sans font-medium">
        Error
      </p>
      <h1 id="error-title" class="font-display text-display-md md:text-display-lg text-foreground">
        404
      </h1>
      <p class="text-2xl md:text-3xl font-display text-foreground-secondary">
        Page Not Found
      </p>
      <p id="error-message" class="text-foreground-secondary text-base md:text-lg leading-relaxed max-w-2xl mx-auto font-sans">
        The page you were trying to reach does not exist or may have been moved.
      </p>
    </section>

    <section class="mt-12 md:mt-16 animate-fade-in" style="animation-delay: 100ms" aria-labelledby="recent-posts-title">
      <h2 id="recent-posts-title" class="font-display text-2xl md:text-3xl text-foreground mb-6">Recent Posts</h2>
      <ul class="space-y-6">
        {recentPosts.map((post: CollectionEntry<'posts'>) => (
          <li>
            <a href={`/blog/${post.id}`} class="group block rounded-md focus:outline-none focus-visible:ring-2 focus-visible:ring-foreground-secondary">
              <time class="text-foreground-muted text-sm font-sans uppercase tracking-wider">
                {post.data.pubDate.toLocaleDateString('en-US', {
                  year: 'numeric',
                  month: 'short',
                  day: 'numeric',
                })}
              </time>
              <p class="font-display text-xl md:text-2xl text-foreground group-hover:text-foreground-secondary transition-colors duration-200 leading-tight mt-1">
                {post.data.title}
              </p>
            </a>
          </li>
        ))}
      </ul>
    </section>

  </main>
</BaseLayout>
