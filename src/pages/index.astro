---
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import SocialLinks from '../components/SocialLinks.astro';

const allPosts = (await getCollection('posts', ({ data }: { data: { draft?: boolean } }) => !data.draft))
  .sort((a: CollectionEntry<'posts'>, b: CollectionEntry<'posts'>) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const posts = allPosts.slice(0, 5);
---

<BaseLayout title="Ken's Blog" showLogo={false}>
  <main>
    <!-- Hero / Intro -->
    <section class="min-h-[50vh] flex flex-col items-center justify-center px-6 py-12">
      <div class="max-w-5xl w-full text-center animate-fade-in">
        <p class="text-foreground-muted text-sm uppercase tracking-[0.3em] mb-6 font-sans font-medium">
          Software Engineer & Designer
        </p>
        <h1 class="font-display text-display-md md:text-display-lg lg:text-display-xl text-foreground mb-8">
          KEN'S<br />
          <span class="text-foreground-muted">BLOG</span>
        </h1>
        <p class="text-xl md:text-2xl text-foreground-secondary max-w-2xl mx-auto leading-relaxed font-sans font-light">
          A place for thoughts on engineering, design, and technology.
        </p>
        <div class="mt-2">
          <SocialLinks />
        </div>
      </div>
    </section>

    <!-- Posts List -->
    <section id="posts" class="max-w-3xl mx-auto px-6 py-24">
      <div class="mb-16 animate-fade-in">
        <a href="/blog" class="text-foreground-muted hover:text-foreground text-sm uppercase tracking-[0.3em] mb-4 font-sans font-medium inline-block transition-colors duration-200">
          Archive
        </a>
        <h2 class="font-display text-display-sm md:text-display-md text-foreground">
          RECENT POSTS
        </h2>
        <p class="text-foreground-secondary mt-4 text-lg">
          {allPosts.length} post{allPosts.length !== 1 ? 's' : ''}
        </p>
      </div>

      <div class="space-y-12">
        {posts.map((post: CollectionEntry<'posts'>, index: number) => (
          <article class="group animate-fade-in" style={`animation-delay: ${index * 100}ms`}>
            <a href={`/blog/${post.id}`} class="block">
              <div class="flex items-baseline justify-between mb-2">
                <time class="text-foreground-muted text-sm font-sans uppercase tracking-wider">
                  {post.data.pubDate.toLocaleDateString('en-US', {
                    year: 'numeric',
                    month: 'short',
                    day: 'numeric',
                  })}
                </time>
                {post.data.tags && post.data.tags.length > 0 && (
                  <span class="text-foreground-muted text-xs uppercase tracking-wider font-sans">
                    {post.data.tags[0]}
                  </span>
                )}
              </div>
              <h3 class="font-display text-2xl md:text-3xl text-foreground group-hover:text-foreground-secondary transition-colors duration-200 leading-tight">
                {post.data.title}
              </h3>
              {post.data.description && (
                <p class="text-foreground-secondary mt-2 text-base leading-relaxed font-sans">
                  {post.data.description}
                </p>
              )}
            </a>
          </article>
        ))}
      </div>
    </section>

    <footer class="text-center pb-12 text-foreground-muted text-xs uppercase tracking-[0.2em] font-sans">
      Built with Astro & Tailwind
    </footer>
  </main>
</BaseLayout>
