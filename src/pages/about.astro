---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="About | Ken's Blog">
  <main class="max-w-3xl mx-auto px-4 py-20">
    <article class="animate-fade-in">
      <h1 class="text-4xl font-bold text-foreground mb-8">About</h1>
      <div class="prose-dark">
        <p>
          Welcome to my blog. I write about software engineering, design, and technology.
          This site is built with Astro, Tailwind CSS, and deployed to Cloudflare Pages.
        </p>
        <p>
          The design philosophy is simple: <strong>dark, minimal, and readable</strong>.
          No tracking, no clutter — just content.
        </p>
      </div>
    </article>
  </main>
</BaseLayout>
