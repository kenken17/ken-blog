---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import SortOrderToggle from '../components/SortOrderToggle.astro';
import BlogTagFilter from '../components/BlogTagFilter.astro';
import { calculateReadingTime } from '../utils/reading-time';
import { getAllTags, getTagCounts } from '../utils/tags';
import { generateJsonLd } from '../utils/seo';
import { getPhotoThumbnail, isPhotoPost } from '../utils/posts';

import type { CollectionEntry } from 'astro:content';

const posts = (await getCollection('posts', ({ data }: { data: { draft?: boolean } }) => !data.draft))
  .sort((a: CollectionEntry<'posts'>, b: CollectionEntry<'posts'>) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const tags = getAllTags(posts);
const tagCounts = getTagCounts(posts);
const postsWithMeta: Array<{
  post: CollectionEntry<'posts'>;
  index: number;
  photoPost: boolean;
  photoThumbnail: ReturnType<typeof getPhotoThumbnail>;
}> = posts.map((post: CollectionEntry<'posts'>, index: number) => ({
  post,
  index,
  photoPost: isPhotoPost(post),
  photoThumbnail: getPhotoThumbnail(post),
}));

const jsonLd = generateJsonLd({
  type: 'CollectionPage',
  title: 'Blog',
  description: "All posts on Ken's blog.",
  canonicalPath: '/blog',
});
---

<BaseLayout
  title="Blog | Ken's Blog"
  description="All posts on Ken's blog."
  canonicalUrl="/blog"
  ogType="website"
  jsonLd={jsonLd}
>
  <main class="max-w-3xl mx-auto px-6 py-24">
    <div class="mb-16 animate-fade-in">
      <p class="text-foreground-muted text-sm uppercase tracking-[0.3em] mb-4 font-sans font-medium">
        Archive
      </p>
      <h1 class="font-display text-display-sm md:text-display-md text-foreground">
        BLOG
      </h1>
      <div class="flex items-center justify-between mt-4">
        <p class="text-foreground-secondary text-lg" data-post-count aria-live="polite">
          {posts.length} post{posts.length !== 1 ? 's' : ''}
        </p>
        <SortOrderToggle />
      </div>
    </div>

    <BlogTagFilter tags={tags} tagCounts={tagCounts} />

    <div class="space-y-12" data-posts-container>
      {postsWithMeta.map(({ post, index, photoPost, photoThumbnail }) => (
        <article class="group animate-fade-in" data-pub-date={post.data.pubDate.toISOString()} data-tags={JSON.stringify(post.data.tags)} style={`animation-delay: ${index * 100}ms`}>
          <div class="flex items-baseline justify-between mb-2 gap-3">
            <div class="flex items-center gap-2 flex-wrap">
              <time class="text-foreground-muted text-sm font-sans uppercase tracking-wider">
                {post.data.pubDate.toLocaleDateString('en-US', {
                  year: 'numeric',
                  month: 'short',
                  day: 'numeric',
                })}
              </time>
              <span class="text-foreground-muted text-sm font-sans uppercase tracking-wider">·</span>
              <span class="text-foreground-muted text-sm font-sans uppercase tracking-wider">{calculateReadingTime(post.body)} min read</span>
              {photoPost && (
                <>
                  <span class="text-foreground-muted text-sm font-sans uppercase tracking-wider">·</span>
                  <span class="inline-flex items-center gap-1 text-foreground-muted text-xs uppercase tracking-wider font-sans" aria-label="Photo post">
                    <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                      <path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"></path>
                      <circle cx="12" cy="13" r="4"></circle>
                    </svg>
                    Photo
                  </span>
                </>
              )}
            </div>
            {post.data.tags && post.data.tags.length > 0 && (
              <a
                href={`/tags/${post.data.tags[0]}`}
                class="text-foreground-muted text-xs uppercase tracking-wider font-sans hover:text-foreground transition-colors duration-200"
                aria-label={`Posts tagged ${post.data.tags[0]}`}
              >
                {post.data.tags[0]}
              </a>
            )}
          </div>

          <a href={`/blog/${post.id}`} class="block">
            {photoPost && photoThumbnail && (
              <div class="mb-4 overflow-hidden border border-background-elevated bg-background-elevated">
                <img
                  src={photoThumbnail.url}
                  srcset={`${photoThumbnail.url}?w=480 480w, ${photoThumbnail.url}?w=768 768w, ${photoThumbnail.url}?w=1200 1200w`}
                  sizes="(min-width: 768px) 42rem, 100vw"
                  alt={photoThumbnail.alt}
                  loading="lazy"
                  decoding="async"
                  class="w-full aspect-[16/9] object-cover group-hover:scale-[1.01] transition-transform duration-300"
                />
              </div>
            )}

            <h2 class="font-display text-2xl md:text-3xl text-foreground group-hover:text-foreground-secondary transition-colors duration-200 leading-tight">
              {post.data.title}
            </h2>

            {post.data.description && (
              <p class="text-foreground-secondary mt-2 text-base leading-relaxed font-sans">
                {post.data.description}
              </p>
            )}
          </a>
        </article>
      ))}
    </div>
  </main>

  <script>
    import { getEffectiveSortOrder, type SortOrder } from '../utils/sort-order.ts';

    function reorderPosts(order: SortOrder) {
      const container = document.querySelector<HTMLDivElement>('[data-posts-container]');
      if (!container) return;

      const articles = Array.from(container.querySelectorAll<HTMLElement>('[data-pub-date]'));
      if (articles.length === 0) return;

      const sorted = articles.sort((a, b) => {
        const aDate = a.getAttribute('data-pub-date') ?? '';
        const bDate = b.getAttribute('data-pub-date') ?? '';
        if (order === 'chronological') {
          return aDate.localeCompare(bDate);
        }
        return bDate.localeCompare(aDate);
      });

      sorted.forEach((article, index) => {
        article.style.animationDelay = `${index * 100}ms`;
        container.appendChild(article);
      });
    }

    function filterPosts(selectedTags: string[]) {
      const container = document.querySelector<HTMLDivElement>('[data-posts-container]');
      if (!container) return;

      const articles = Array.from(container.querySelectorAll<HTMLElement>('[data-tags]'));
      const postCountEl = document.querySelector<HTMLParagraphElement>('[data-post-count]');

      let visibleCount = 0;

      articles.forEach((article) => {
        const tagsAttr = article.getAttribute('data-tags');
        if (!tagsAttr) return;

        let postTags: string[] = [];
        try {
          postTags = JSON.parse(tagsAttr);
        } catch {
          postTags = [];
        }

        const shouldShow = selectedTags.length === 0 || selectedTags.some((tag) => postTags.includes(tag));

        if (shouldShow) {
          article.classList.remove('hidden');
          visibleCount++;
        } else {
          article.classList.add('hidden');
        }
      });

      // Re-apply animation delays to visible posts
      const visibleArticles = articles.filter((a) => !a.classList.contains('hidden'));
      visibleArticles.forEach((article, index) => {
        article.style.animationDelay = `${index * 100}ms`;
      });

      // Update post count
      if (postCountEl) {
        postCountEl.textContent = `${visibleCount} post${visibleCount !== 1 ? 's' : ''}`;
      }
    }

    // Apply stored preferences on initial load
    const initialOrder = getEffectiveSortOrder();
    reorderPosts(initialOrder);

    // Listen for sort-order toggle changes
    window.addEventListener('sort-order:change', (event: Event) => {
      const customEvent = event as CustomEvent<{ order: SortOrder }>;
      reorderPosts(customEvent.detail.order);
    });

    // Listen for tag filter changes
    window.addEventListener('blog-tag-filter:change', (event: Event) => {
      const customEvent = event as CustomEvent<{ tags: string[] }>;
      filterPosts(customEvent.detail.tags);
    });
  </script>
</BaseLayout>
