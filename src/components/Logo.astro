---
interface Props {
  class?: string;
}

const { class: className = "" } = Astro.props;
---

<a
  href="/"
  aria-label="Ken's Blog home"
  class:list={[
    "font-display text-2xl md:text-3xl text-foreground uppercase tracking-wide font-semibold",
    "hover:text-foreground-secondary transition-colors duration-200 inline-block",
    className,
  ]}
>
  KEN'S BLOG
</a>
