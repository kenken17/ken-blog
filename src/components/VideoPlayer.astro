---
interface Props {
  url: string;
  autoplay?: boolean;
  loop?: boolean;
  controls?: boolean;
  caption?: string;
}

const { url, autoplay = false, loop = false, controls = true, caption } = Astro.props;
---

<div class="video-container my-8">
  <video
    class="w-full max-w-full rounded-lg shadow-sm border border-background-elevated"
    src={url}
    autoplay={autoplay}
    loop={loop}
    controls={controls}
    preload="metadata"
  >
    <p class="text-foreground-muted text-sm">
      Your browser doesn't support video playback. 
      <a href={url} class="text-foreground underline hover:text-foreground-secondary transition-colors">
        Download the video
      </a>
    </p>
  </video>
  
  {caption && (
    <p class="mt-3 text-sm text-foreground-muted italic text-center">
      {caption}
    </p>
  )}
</div>

<style>
  .video-container video {
    height: auto;
    display: block;
    margin: 0 auto;
  }
  
  /* Ensure video is responsive */
  .video-container video {
    max-height: 70vh;
    object-fit: contain;
  }
</style>