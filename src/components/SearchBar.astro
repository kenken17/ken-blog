<div class="relative" data-search-container>
  <!-- Desktop: always visible input -->
  <div class="hidden md:flex items-center gap-2 relative">
    <svg
      xmlns="http://www.w3.org/2000/svg"
      width="18"
      height="18"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      class="text-foreground-muted absolute left-3 pointer-events-none"
      aria-hidden="true"
    >
      <circle cx="11" cy="11" r="8" />
      <path d="m21 21-4.3-4.3" />
    </svg>
    <input
      type="search"
      role="search"
      aria-label="Search posts"
      placeholder="Search..."
      data-search-input
      class="w-48 lg:w-64 bg-background-surface border border-background-elevated rounded-md py-2 pl-10 pr-3 text-sm text-foreground placeholder:text-foreground-muted focus:outline-none focus:border-foreground-secondary focus:ring-1 focus:ring-foreground-secondary transition-all"
    />
  </div>

  <!-- Mobile: search icon button -->
  <button
    type="button"
    aria-label="Open search"
    data-search-mobile-toggle
    class="md:hidden p-2 text-foreground-secondary hover:text-foreground transition-colors"
  >
    <svg
      xmlns="http://www.w3.org/2000/svg"
      width="20"
      height="20"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      aria-hidden="true"
    >
      <circle cx="11" cy="11" r="8" />
      <path d="m21 21-4.3-4.3" />
    </svg>
  </button>

  <!-- Mobile: expanded search overlay -->
  <div
    data-search-mobile-overlay
    class="fixed inset-0 bg-background/95 backdrop-blur-sm z-40 hidden flex-col items-center justify-start pt-24 px-6"
  >
    <div class="w-full max-w-md relative">
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="18"
        height="18"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        class="text-foreground-muted absolute left-3 top-1/2 -translate-y-1/2 pointer-events-none"
        aria-hidden="true"
      >
        <circle cx="11" cy="11" r="8" />
        <path d="m21 21-4.3-4.3" />
      </svg>
      <input
        type="search"
        role="search"
        aria-label="Search posts"
        placeholder="Search..."
        data-search-mobile-input
        class="w-full bg-background-surface border border-background-elevated rounded-md py-3 pl-10 pr-10 text-base text-foreground placeholder:text-foreground-muted focus:outline-none focus:border-foreground-secondary focus:ring-1 focus:ring-foreground-secondary"
      />
      <button
        type="button"
        aria-label="Close search"
        data-search-mobile-close
        class="absolute right-3 top-1/2 -translate-y-1/2 text-foreground-muted hover:text-foreground transition-colors"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="18"
          height="18"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <path d="M18 6 6 18" />
          <path d="m6 6 12 12" />
        </svg>
      </button>
    </div>
  </div>

  <!-- Results dropdown (shared for desktop + mobile) -->
  <div
    data-search-results
    class="hidden absolute top-full right-0 mt-2 w-80 lg:w-96 max-h-96 overflow-y-auto bg-background-surface border border-background-elevated shadow-lg rounded-md z-50 animate-fade-in"
  >
    <div data-search-empty class="hidden px-4 py-6 text-center text-foreground-muted text-sm">
      No results found
    </div>
    <ul data-search-list class="divide-y divide-background-elevated"></ul>
  </div>
</div>

<script>
  import { initSearch } from '../scripts/search';
  initSearch();
</script>
