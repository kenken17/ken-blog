{
  "name": "ken-blog",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "prebuild": "tsx scripts/generate-search-index.ts && npm run generate-pwa-icons",
    "generate-pwa-icons": "tsx scripts/generate-pwa-icons.ts",
    "build": "npm run prebuild && astro check && astro build",
    "preview": "astro preview",
    "deploy": "npm run build && wrangler pages deploy dist --project-name=ken-blog",
    "astro": "astro",
    "test": "vitest",
    "test:e2e": "playwright test",
    "typecheck": "astro check"
  },
  "dependencies": {
    "@astrojs/mdx": "^5.0.6",
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "^3.7.2",
    "@shikijs/transformers": "^4.1.0",
    "@tailwindcss/typography": "^0.5.10",
    "astro": "^6.3.1",
    "pi-subagents": "^0.24.4",
    "tailwindcss": "^3.4.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.0",
    "@playwright/test": "^1.59.1",
    "@testing-library/dom": "^10.0.0",
    "@types/node": "^25.6.2",
    "@vitest/coverage-v8": "^4.1.6",
    "autoprefixer": "^10.4.0",
    "jsdom": "^29.1.1",
    "playwright": "^1.45.0",
    "postcss": "^8.4.0",
    "tsx": "^4.21.0",
    "typescript": "^5.4.0",
    "vitest": "^4.1.6"
  },
  "overrides": {
    "yaml": "^2.9.0"
  }
}
